{
  "openapi": "3.0.3",
  "info": {
    "title": "ChronoCards World Map API",
    "description": "ChronoCards 世界地图/场景 API 契约 | 版本v2.0 | 日期2026-04-11 | 状态草稿",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://api.chronocards.game/api/v1",
      "description": "生产环境（REST API）"
    },
    {
      "url": "http://localhost:8080/api/v1",
      "description": "本地开发（REST API）"
    }
  ],
  "webSocket": {
    "description": "实时游戏事件推送（WebSocket）",
    "url": "wss://api.chronocards.game/ws/v1",
    "url_local": "ws://localhost:8080/ws/v1",
    "protocol_doc": "/api_schema_websocket.md",
    "authentication": "HTTP Header: Authorization: Bearer {jwt_token} 或连接建立后发送 auth 消息",
    "events": [
      {
        "name": "event_card_draw",
        "description": "抽牌事件（多人同步场景）"
      },
      {
        "name": "event_world_map_update",
        "description": "玩家位置变化推送"
      },
      {
        "name": "event_battle_update",
        "description": "战斗状态变化推送"
      },
      {
        "name": "event_player_status",
        "description": "玩家属性变化推送"
      },
      {
        "name": "event_deck_exhausted",
        "description": "卡组耗尽通知"
      },
      {
        "name": "event_encounter",
        "description": "遭遇敌人/随机事件"
      },
      {
        "name": "event_narrative",
        "description": "叙事内容生成推送"
      }
    ]
  },
  "paths": {
    "/world": {
      "get": {
        "summary": "获取世界概览",
        "description": "返回九州江湖世界的整体信息，包括所有大区和统计数据",
        "tags": ["World"],
        "responses": {
          "200": {
            "description": "世界概览",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorldOverview"
                }
              }
            }
          }
        }
      }
    },
    "/world/regions": {
      "get": {
        "summary": "获取所有大区列表",
        "description": "返回九州江湖所有大区的基本信息，可按条件筛选",
        "tags": ["World"],
        "parameters": [
          {
            "name": "danger_level",
            "in": "query",
            "description": "按危险等级筛选",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          {
            "name": "climate",
            "in": "query",
            "description": "按气候类型筛选",
            "schema": {
              "type": "string",
              "enum": ["温带季风", "亚热带季风", "温带大陆性", "热带沙漠", "热带季风"]
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "按标签筛选（多个标签用逗号分隔）",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "大区列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "world": {
                      "type": "string",
                      "example": "jiuzhou"
                    },
                    "world_name": {
                      "type": "string",
                      "example": "九州江湖"
                    },
                    "total_regions": {
                      "type": "integer",
                      "example": 5
                    },
                    "regions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Region"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/world/regions/{region_id}": {
      "get": {
        "summary": "获取大区详情",
        "description": "根据大区ID获取详细信息，包括该大区下的所有场景",
        "tags": ["World"],
        "parameters": [
          {
            "name": "region_id",
            "in": "path",
            "required": true,
            "description": "大区ID",
            "schema": {
              "type": "string",
              "example": "region-central-plains"
            }
          },
          {
            "name": "include_locations",
            "in": "query",
            "description": "是否包含场景列表",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "大区详情",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "region": {
                      "$ref": "#/components/schemas/Region"
                    },
                    "locations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Location"
                      }
                    },
                    "stats": {
                      "type": "object",
                      "properties": {
                        "total_locations": {
                          "type": "integer"
                        },
                        "unlocked_count": {
                          "type": "integer"
                        },
                        "visited_count": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "大区不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/world/regions/{region_id}/locations": {
      "get": {
        "summary": "获取大区下的所有场景",
        "description": "返回指定大区的所有场景列表，支持类型筛选",
        "tags": ["World"],
        "parameters": [
          {
            "name": "region_id",
            "in": "path",
            "required": true,
            "description": "大区ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "按场景类型筛选",
            "schema": {
              "type": "string",
              "enum": ["city", "town", "village", "wilderness", "dungeon", "special"]
            }
          },
          {
            "name": "unlocked_only",
            "in": "query",
            "description": "仅返回已解锁的场景",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "danger_level",
            "in": "query",
            "description": "按危险等级筛选",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "场景列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "region": {
                      "$ref": "#/components/schemas/Region"
                    },
                    "locations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Location"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "大区不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/world/locations": {
      "get": {
        "summary": "搜索场景",
        "description": "全局搜索场景，支持名称、标签、类型等条件",
        "tags": ["World"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "搜索关键词（匹配名称、描述）",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "场景类型",
            "schema": {
              "type": "string",
              "enum": ["city", "town", "village", "wilderness", "dungeon", "special"]
            }
          },
          {
            "name": "region_id",
            "in": "query",
            "description": "限定大区",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "unlocked",
            "in": "query",
            "description": "是否已解锁",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "搜索结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer"
                    },
                    "locations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Location"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/world/locations/{location_id}": {
      "get": {
        "summary": "获取场景详情",
        "description": "根据场景ID获取详细信息，包括可用发牌员、关联章节等",
        "tags": ["World"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "description": "场景ID",
            "schema": {
              "type": "string",
              "example": "loc-changan"
            }
          },
          {
            "name": "include_dealers",
            "in": "query",
            "description": "是否包含可用发牌员详情",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "场景详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationDetail"
                }
              }
            }
          },
          "404": {
            "description": "场景不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/world/locations/{location_id}/connections": {
      "get": {
        "summary": "获取场景连通性",
        "description": "返回从该场景可到达的其他场景及路线信息",
        "tags": ["World"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "description": "场景ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connection_type",
            "in": "query",
            "description": "按连接类型筛选",
            "schema": {
              "type": "string",
              "enum": ["road", "river", "mountain", "teleport", "special"]
            }
          },
          {
            "name": "max_danger",
            "in": "query",
            "description": "最大危险等级筛选",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "连通性信息",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "current_location": {
                      "$ref": "#/components/schemas/Location"
                    },
                    "connections": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LocationConnection"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "场景不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/players/{player_id}/current-location": {
      "get": {
        "summary": "获取玩家当前位置",
        "description": "返回玩家当前所在的大区和场景，以及访问历史统计",
        "tags": ["Player"],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "description": "玩家ID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "玩家位置信息",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "player_id": {
                      "type": "string"
                    },
                    "current_location": {
                      "$ref": "#/components/schemas/Location"
                    },
                    "current_region": {
                      "$ref": "#/components/schemas/Region"
                    },
                    "visited_count": {
                      "type": "object",
                      "properties": {
                        "locations": {
                          "type": "integer",
                          "description": "已访问场景数"
                        },
                        "regions": {
                          "type": "integer",
                          "description": "已访问大区数"
                        }
                      }
                    },
                    "travel_stats": {
                      "type": "object",
                      "properties": {
                        "total_travels": {
                          "type": "integer"
                        },
                        "total_distance": {
                          "type": "integer"
                        },
                        "last_travel_at": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "玩家不存在或尚未设置位置",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/players/{player_id}/navigate": {
      "post": {
        "summary": "导航到新场景",
        "description": "玩家请求导航到指定场景，系统会验证路径并返回导航结果",
        "tags": ["Player"],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "description": "玩家ID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["target_location_id"],
                "properties": {
                  "target_location_id": {
                    "type": "string",
                    "description": "目标场景ID",
                    "example": "loc-suzhou"
                  },
                  "use_optimal_route": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否使用最优路线（否则由玩家选择路线）"
                  },
                  "preferred_connection_id": {
                    "type": "string",
                    "description": "玩家偏好的路线ID（当 use_optimal_route=false 时）"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "导航成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "你踏上了前往苏州城的旅程，沿着京杭大运河顺流而下。"
                    },
                    "travel_time": {
                      "type": "string",
                      "description": "预计旅行时间",
                      "example": "1天"
                    },
                    "route": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/LocationSummary"
                          },
                          "description": "路线经过的场景（途经点）"
                        },
                        "total_distance": {
                          "type": "integer"
                        },
                        "dangers": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "location": {
                                "type": "string"
                              },
                              "danger_level": {
                                "type": "integer"
                              },
                              "description": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    },
                    "new_location": {
                      "$ref": "#/components/schemas/Location"
                    },
                    "available_dealers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dealer"
                      },
                      "description": "新场景可用的发牌员"
                    },
                    "encounter_probability": {
                      "type": "object",
                      "properties": {
                        "on_route": {
                          "type": "number",
                          "format": "float",
                          "description": "途中遭遇概率 0-1"
                        },
                        "at_destination": {
                          "type": "number",
                          "format": "float",
                          "description": "到达后遭遇概率 0-1"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "导航失败（位置不可达、被锁定等）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NavigateError"
                }
              }
            }
          },
          "404": {
            "description": "目标场景不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/players/{player_id}/visited": {
      "get": {
        "summary": "获取玩家访问历史",
        "description": "返回玩家已访问的大区和场景列表",
        "tags": ["Player"],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "description": "玩家ID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "region_id",
            "in": "query",
            "description": "限定大区",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "访问历史",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "player_id": {
                      "type": "string"
                    },
                    "visited_regions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Region"
                      }
                    },
                    "visited_locations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Location"
                      }
                    },
                    "exploration_rate": {
                      "type": "object",
                      "properties": {
                        "regions": {
                          "type": "number",
                          "format": "float",
                          "description": "大区探索百分比"
                        },
                        "locations": {
                          "type": "number",
                          "format": "float",
                          "description": "场景探索百分比"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/players/{player_id}/set-location": {
      "post": {
        "summary": "设置玩家位置（GM/测试用）",
        "description": "直接设置玩家当前位置，用于GM工具或测试",
        "tags": ["Player"],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "description": "玩家ID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["location_id"],
                "properties": {
                  "location_id": {
                    "type": "string",
                    "description": "目标场景ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "设置成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "current_location": {
                      "$ref": "#/components/schemas/Location"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorldOverview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "jiuzhou"
          },
          "name": {
            "type": "string",
            "example": "九州江湖"
          },
          "description": {
            "type": "string",
            "example": "一个架空的武侠世界，九州大地，英豪辈出"
          },
          "total_regions": {
            "type": "integer",
            "example": 5
          },
          "total_locations": {
            "type": "integer",
            "example": 35
          },
          "regions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RegionSummary"
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "version": {
                "type": "string"
              },
              "last_updated": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "RegionSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "region-central-plains"
          },
          "name": {
            "type": "string",
            "example": "中原武林"
          },
          "display_order": {
            "type": "integer"
          },
          "danger_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "location_count": {
            "type": "integer"
          }
        }
      },
      "Region": {
        "type": "object",
        "properties": {
          "id": {
