{
  "openapi": "3.0.3",
  "info": {
    "title": "ChronoCards Game API",
    "description": "ChronoCards 事件卡组驱动AI生成世界后端API契约 | 版本v1.0 | 日期2026-04-11 | 状态已锁定",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.chronocards.game/api/v1",
      "description": "生产环境"
    },
    {
      "url": "http://localhost:8080/api/v1",
      "description": "本地开发"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "健康检查",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/players/{player_id}": {
      "get": {
        "summary": "获取玩家详情",
        "tags": [
          "Player"
        ],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Player"
                }
              }
            }
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      },
      "patch": {
        "summary": "更新玩家状态",
        "tags": [
          "Player"
        ],
        "description": "支持增量更新HP/MP/体力/剑意值/经验/技能/声望",
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePlayerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Player"
                }
              }
            }
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      }
    },
    "/players/{player_id}/battle-state": {
      "get": {
        "summary": "获取玩家战斗状态快照",
        "tags": [
          "Player"
        ],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BattlePlayerState"
                }
              }
            }
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      }
    },
    "/player/status/{player_id}": {
      "get": {
        "summary": "获取玩家完整状态",
        "tags": [
          "Player"
        ],
        "parameters": [
          {
            "name": "player_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Player"
                }
              }
            }
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      }
    },
    "/decks": {
      "post": {
        "summary": "创建卡组",
        "tags": [
          "Deck"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeckRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deck"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误"
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      }
    },
    "/decks/{deck_id}": {
      "get": {
        "summary": "获取卡组详情",
        "tags": [
          "Deck"
        ],
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deck"
                }
              }
            }
          },
          "404": {
            "description": "卡组不存在"
          }
        }
      }
    },
    "/decks/{deck_id}/draw": {
      "post": {
        "summary": "抽牌",
        "tags": [
          "Deck"
        ],
        "description": "从卡组抽取1-3张卡牌",
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DrawRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "抽牌成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DrawResponse"
                }
              }
            }
          },
          "404": {
            "description": "卡组不存在"
          }
        }
      }
    },
    "/decks/{deck_id}/hand": {
      "get": {
        "summary": "获取当前手牌",
        "tags": [
          "Deck"
        ],
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HandResponse"
                }
              }
            }
          },
          "404": {
            "description": "卡组不存在"
          }
        }
      }
    },
    "/decks/{deck_id}/reshuffle": {
      "post": {
        "summary": "洗牌",
        "tags": [
          "Deck"
        ],
        "description": "将弃牌堆重新洗入卡组",
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "洗牌成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deck"
                }
              }
            }
          },
          "404": {
            "description": "卡组不存在"
          }
        }
      }
    },
    "/decks/{deck_id}/adjust": {
      "post": {
        "summary": "动态调整卡组",
        "tags": [
          "Deck"
        ],
        "description": "根据玩家状态或发牌员类型调整卡组抽牌顺序",
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeckAdjustRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "调整成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deck"
                }
              }
            }
          },
          "404": {
            "description": "卡组不存在"
          }
        }
      }
    },
    "/element/reactions": {
      "post": {
        "summary": "计算元素反应",
        "tags": [
          "Element"
        ],
        "description": "计算攻击者元素与防御者元素之间的反应结果",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ElementReactionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "反应计算结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ElementReactionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/element/attach": {
      "post": {
        "summary": "附着元素",
        "tags": [
          "Element"
        ],
        "description": "给目标附着元素并检查是否触发元素反应",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ElementAttachRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "附着结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ElementAttachResponse"
                }
              }
            }
          }
        }
      }
    },
    "/battle/action": {
      "post": {
        "summary": "统一战斗动作",
        "tags": [
          "Battle"
        ],
        "description": "统一处理闪避/格挡/反击/攻击四种战斗动作",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BattleActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "动作结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BattleActionResponse"
                }
              }
            }
          },
          "400": {
            "description": "无效action"
          },
          "404": {
            "description": "玩家不存在"
          }
        }
      }
    },
    "/battle/calculate": {
      "post": {
        "summary": "计算战斗伤害",
        "tags": [
          "Battle"
        ],
        "description": "计算包含元素反应和暴击的最终伤害值",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BattleCalculateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "伤害计算结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BattleDamageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/battle/dodge": {
      "post": {
        "summary": "闪避判定",
        "tags": [
          "Battle"
        ],
        "description": "基于时机的闪避判定",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DodgeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "闪避结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DodgeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/battle/block": {
      "post": {
        "summary": "格挡判定",
        "tags": [
          "Battle"
        ],
        "description": "基于时机的格挡判定",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlockRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "格挡结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockResponse"
                }
              }
            }
          }
        }
      }
    },
    "/narrative/generate": {
      "post": {
        "summary": "AI生成叙事内容",
        "tags": [
          "Narrative"
        ],
        "description": "调用AI生成游戏叙事内容，支持DeepSeek/Kimi/OpenAI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NarrativeTriggerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "生成的叙事内容",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NarrativeContent"
                }
              }
            }
          },
          "500": {
            "description": "AI生成失败"
          }
        }
      }
    },
    "/narrative/deck-event": {
      "post": {
        "summary": "卡组事件叙事",
        "tags": [
          "Narrative"
        ],
        "description": "抽到卡牌后触发AI叙事",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeckEventNarrativeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "叙事内容",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NarrativeContent"
                }
              }
            }
          },
          "400": {
            "description": "缺少card参数"
          }
        }
      }
    },
    "/dealers": {
      "get": {
        "summary": "获取发牌员列表",
        "tags": [
          "Dealer"
        ],
        "responses": {
          "200": {
            "description": "发牌员列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dealers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dealer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建发牌员",
        "tags": [
          "Dealer"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "teahouse",
                      "bounty_board",
                      "enemy",
                      "inn",
                      "merchant",
                      "dynamic_encounter",
                      "environment"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "interaction_prompt": {
                    "type": "string"
                  },
                  "weight": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dealer"
                }
              }
            }
          },
          "400": {
            "description": "缺少必填字段"
          }
        }
      }
    },
    "/dealers/{dealer_id}/trigger": {
      "post": {
        "summary": "触发发牌员",
        "tags": [
          "Dealer"
        ],
        "description": "玩家与发牌员交互触发抽牌和叙事",
        "parameters": [
          {
            "name": "dealer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "player_id",
                  "deck_id"
                ],
                "properties": {
                  "player_id": {
                    "type": "string"
                  },
                  "deck_id": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "触发结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dealer_id": {
                      "type": "string"
                    },
                    "dealer_name": {
                      "type": "string"
                    },
                    "drawn_card": {
                      "$ref": "#/components/schemas/Card"
                    },
                    "deck_exhausted": {
                      "type": "boolean"
                    },
                    "hint": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "发牌员或卡组不存在"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Player": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "level": {
            "type": "integer"
          },
          "exp": {
            "type": "integer"
          },
          "hp": {
            "type": "integer"
          },
          "max_hp": {
            "type": "integer"
          },
          "mp": {
            "type": "integer"
          },
          "max_mp": {
            "type": "integer"
          },
          "sword_intent": {
            "type": "integer"
          },
          "stamina": {
            "type": "integer"
          },
          "max_stamina": {
            "type": "integer"
          },
          "element_mastery": {
            "$ref": "#/components/schemas/ElementMastery"
          },
          "faction": {
            "type": "string"
          },
          "reputation": {
            "$ref": "#/components/schemas/Reputation"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreatePlayerRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 32
          },
          "faction": {
            "type": "string",
            "default": "none",
            "enum": [
              "none",
              "mingjiao",
              "zhengpai",
              "jinyiwei"
            ]
          }
        }
      },
      "UpdatePlayerRequest": {
        "type": "object",
        "properties": {
          "hp_delta": {
            "type": "integer"
          },
          "mp_delta": {
            "type": "integer"
          },
          "sword_intent_delta": {
            "type": "integer"
          },
          "stamina_delta": {
            "type": "integer"
          },
          "exp_delta": {
            "type": "integer"
          },
          "level_up": {
            "type": "boolean"
          },
          "skill_add": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reputation_delta": {
            "$ref": "#/components/schemas/ReputationDeltaRequest"
          }
        }
      },
      "ReputationDeltaRequest": {
        "type": "object",
        "properties": {
          "mingjiao": {
            "type": "integer"
          },
          "zhengpai": {
            "type": "integer"
          },
          "jinyiwei": {
            "type": "integer"
          }
        }
      },
      "ElementMastery": {
        "type": "object",
        "properties": {
          "wind": {
            "type": "integer"
          },
          "fire": {
            "type": "integer"
          },
          "water": {
            "type": "integer"
          },
          "thunder": {
            "type": "integer"
          },
          "ice": {
            "type": "integer"
          },
          "poison": {
            "type": "integer"
          }
        }
      },
      "Reputation": {
        "type": "object",
        "properties": {
          "mingjiao": {
            "type": "integer"
          },
          "zhengpai": {
            "type": "integer"
          },
          "jinyiwei": {
            "type": "integer"
          }
        }
      },
      "BattlePlayerState": {
        "type": "object",
        "properties": {
          "player_id": {
            "type": "string"
          },
          "hp": {
            "type": "integer"
          },
          "max_hp": {
            "type": "integer"
          },
          "mp": {
            "type": "integer"
          },
          "max_mp": {
            "type": "integer"
          },
          "stamina": {
            "type": "integer"
          },
          "max_stamina": {
            "type": "integer"
          },
          "sword_intent": {
            "type": "integer"
          },
          "element_attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ElementAttachment"
            }
          },
          "status_effects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StatusEffect"
            }
          },
          "active_skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Skill"
            }
          }
        }
      },
      "Deck": {
        "type": "object",
        "properties": {
